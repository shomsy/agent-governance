{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Harness Incident Report",
  "type": "object",
  "required": ["incident_id", "severity", "status", "impact"],
  "properties": {
    "incident_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["SEV1", "SEV2", "SEV3"] },
    "status": { "type": "string", "enum": ["INVESTIGATING", "MITIGATED", "RESOLVED"] },
    "impact": { "type": "string" },
    "mitigation_steps": { "type": "array", "items": { "type": "string" } }
  }
}
