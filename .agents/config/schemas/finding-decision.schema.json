{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding Decision",
  "description": "Machine-verifiable decision record for a scanner-detected finding. Prevents Markdown-only closure anti-pattern.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id", "tool", "findingFingerprint", "decision",
    "classification", "reason",
    "createdAt", "updatedAt", "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^FD-[0-9]{8}-[0-9]{3}$",
      "description": "Unique decision ID, format: FD-YYYYMMDD-NNN"
    },
    "tool": {
      "type": "string",
      "description": "Name of the detecting tool (e.g., verify-governance.sh, check-profile-leakage.sh)"
    },
    "findingFingerprint": {
      "type": "string",
      "minLength": 1,
      "description": "Stable fingerprint: SHA-256 hex or tool-specific format (e.g., avax:path:line:token)"
    },
    "file": {
      "type": "string",
      "description": "File path where the finding was detected"
    },
    "line": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Line number, if applicable"
    },
    "pattern": {
      "type": ["string", "null"],
      "description": "Matched pattern or rule ID, if applicable"
    },
    "originalSeverity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info", "BLOCKER", "HIGH", "MEDIUM", "LOW", "INFO"],
      "description": "Severity as reported by the detecting tool"
    },
    "decision": {
      "type": "string",
      "enum": [
        "FIXED",
        "ACCEPTED_EXCEPTION",
        "DEFERRED",
        "FALSE_POSITIVE",
        "COMPOSITION_ROOT_ALLOWED",
        "SCAFFOLD_DEFERRED",
        "TOOLING_BUG",
        "INFO_ALLOWED",
        "YELLOW_ACCEPTED",
        "YELLOW_DEFERRED"
      ],
      "description": "Resolution decision type"
    },
    "decisionSeverity": {
      "type": "string",
      "enum": ["RED", "YELLOW", "INFO", "GREEN", "critical", "high", "medium", "low", "info"],
      "description": "Severity after decision is applied"
    },
    "classification": {
      "type": "string",
      "description": "Human-readable classification of the finding"
    },
    "reason": {
      "type": "string",
      "description": "Why this decision was made"
    },
    "owner": {
      "type": ["string", "null"],
      "description": "Person or role responsible for this decision"
    },
    "expiry": {
      "type": ["string", "null"],
      "description": "ISO-8601 expiry date, 'never', or trigger condition (e.g., 'on SCAFFOLD→ACTIVE promotion')"
    },
    "mitigation": {
      "type": ["string", "null"],
      "description": "Compensating control or workaround, if applicable"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to supporting evidence files"
    },
    "approvedBy": {
      "type": ["string", "null"],
      "description": "Person or agent who approved this decision"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO-8601 creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO-8601 last update timestamp"
    },
    "status": {
      "type": "string",
      "enum": ["active", "expired", "revoked", "superseded"],
      "description": "Current lifecycle status"
    }
  }
}
