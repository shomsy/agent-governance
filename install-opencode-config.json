{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      ".agents/hooks/supervisor.sh*": "allow",
      ".agents/hooks/validate-artifact.py*": "allow"
    },
    "task": {
      "*": "deny",
      "harness-*": "allow"
    }
  },
  "mcpServers": {
    "docs": {
      "command": "python3",
      "args": ["{HARNESS_ROOT}/.agents/mcp/docs-mcp-server.py"],
      "env": {}
    },
    "github": {
      "command": "python3",
      "args": ["{HARNESS_ROOT}/.agents/mcp/github-ro-mcp-server.py"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "ci-logs": {
      "command": "python3",
      "args": ["{HARNESS_ROOT}/.agents/mcp/ci-logs-mcp-server.py"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "agents": {
    "harness-mapper": {
      "description": "Maps codebase and finds relevant files (read-only)",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "webfetch": "deny",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "cat *": "allow"
        }
      }
    },
    "harness-researcher": {
      "description": "Researches documentation and API references",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "ask",
          "grep *": "allow",
          "rg *": "allow",
          "curl *": "allow",
          "cat *": "allow"
        },
        "mcp": {
          "docs": "allow",
          "github": "read"
        }
      }
    },
    "harness-executor": {
      "description": "Executes code changes - implements features and fixes",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "allow",
        "webfetch": "deny",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "npm *": "ask",
          "python *": "ask",
          "pytest *": "allow",
          "jest *": "allow"
        }
      }
    },
    "harness-reviewer": {
      "description": "Reviews code changes for risks and correctness",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "webfetch": "deny",
        "bash": {
          "*": "ask",
          "git *": "allow",
          "git diff*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cat *": "allow"
        }
      }
    }
  },
  "routing": {
    "system": "harness-supervisor",
    "default": "harness-mapper",
    "rules": {
      "map|where|find|explore|trace|understand|explain": "harness-mapper",
      "docs|documentation|api|version|learn about": "harness-researcher",
      "implement|fix|refactor|change|modify|add|create|update|bug|error": "harness-executor",
      "review|check|verify|audit|risks|security": "harness-reviewer",
      "ci|build|deploy|failed|log|test failure": "harness-researcher"
    }
  }
}
